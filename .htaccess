RewriteEngine On

# Se arquivo ou diretorio existe, serve direto
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Rotas amigaveis - paginas
RewriteRule ^login/?$              frontend/pages/login.php [L]
RewriteRule ^cadastro/?$           frontend/pages/cadastro.php [L]
RewriteRule ^dashboard/?$          frontend/pages/dashboard.php [L]
RewriteRule ^perfil/?$             frontend/pages/perfil.php [L]
RewriteRule ^gerenciar/?$          frontend/pages/gerenciar.php [L]
RewriteRule ^portfolio/?$          frontend/pages/portfolio.php [L]
RewriteRule ^novo-servico/?$       frontend/pages/novo-servico.php [L]
RewriteRule ^chat/?$               frontend/pages/chat.php [L]
RewriteRule ^meus-pedidos/?$       frontend/pages/meus-pedidos.php [L]
RewriteRule ^detalhes/?$           frontend/pages/detalhes.php [L]
RewriteRule ^esqueci-senha/?$      frontend/pages/esqueci-senha.php [L]
RewriteRule ^avaliar-prestador/?$  frontend/pages/avaliar-prestador.php [L]
RewriteRule ^ver-perfil/?$         frontend/pages/ver-perfil.php [L]
RewriteRule ^logout/?$             backend/controllers/AuthController.php?action=logout [L]

# Landing page
RewriteRule ^$ frontend/index.php [L]
